#!/usr/bin/env bash
set -euo pipefail

# When the script is piped (e.g. bash <(curl ...)), stdin is the pipe, not the
# terminal. Reassign stdin to /dev/tty so read always talks to the user.
exec </dev/tty

IMAGE="${BENCHMARK_IMAGE:-mablospate/tfg-bench:latest}"

CPU_MODEL="unknown"
CPU_PHYSICAL=1
CPU_LOGICAL=1
CPU_FREQ_MHZ=0
RAM_GB_F="0.0"
RAM_GB_I=0
HAS_NVIDIA=0
GPU_FLAGS=""
GPU_MODEL=""
DOCKER_MEM_GB=4
DOCKER_CPUS=1

# Colima state tracking — set during ensure_docker, used by restore_colima
COLIMA_STARTED=0        # we started Colima from scratch
COLIMA_RESTARTED=0      # we restarted an existing Colima
COLIMA_ORIG_GB=0        # original memory before restart
COLIMA_ORIG_CPU=0       # original CPU count before restart

BENCH_CONTAINER_NAME=""   # set while container is running, cleared after

TIME_BUDGET_MINS=0
TIMER_PID=""

ask_time_budget() {
    local ans
    read -r -p "Tiempo límite en minutos (Enter = sin límite): " ans
    if [[ "$ans" =~ ^[0-9]+$ ]] && (( ans > 0 )); then
        TIME_BUDGET_MINS=$ans
    fi
}

_on_exit() {
    if [[ -n "$TIMER_PID" ]]; then
        kill "$TIMER_PID" 2>/dev/null
        wait "$TIMER_PID" 2>/dev/null
    fi
    [[ -n "${BENCH_CONTAINER_NAME:-}" ]] && docker stop "$BENCH_CONTAINER_NAME" >/dev/null 2>&1 || true
    cleanup_image
    restore_colima
}
trap '_on_exit' EXIT

detect_hardware() {
    local os
    os="$(uname -s)"

    if [[ "$os" == "Darwin" ]]; then
        CPU_MODEL=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || sysctl -n hw.model 2>/dev/null || echo "unknown")
        CPU_PHYSICAL=$(sysctl -n hw.physicalcpu 2>/dev/null || echo 1)
        CPU_LOGICAL=$(sysctl -n hw.logicalcpu 2>/dev/null || echo 1)
        CPU_FREQ_HZ=$(sysctl -n hw.cpufrequency_max 2>/dev/null || sysctl -n hw.cpufrequency 2>/dev/null || echo 0)
        CPU_FREQ_MHZ=$(( CPU_FREQ_HZ / 1000000 ))
        RAM_BYTES=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
        RAM_GB_I=$(( RAM_BYTES / 1073741824 ))
        RAM_GB_F=$(awk "BEGIN{printf \"%.1f\", $RAM_BYTES/1073741824}")
    else
        CPU_MODEL=$(grep "model name" /proc/cpuinfo 2>/dev/null | head -1 | cut -d: -f2- | xargs 2>/dev/null || \
                    lscpu 2>/dev/null | grep "Model name" | cut -d: -f2- | xargs 2>/dev/null || echo "unknown")
        CPU_PHYSICAL=$(lscpu -p=CORE 2>/dev/null | grep -v "^#" | sort -u | wc -l 2>/dev/null || nproc 2>/dev/null || echo 1)
        CPU_LOGICAL=$(nproc 2>/dev/null || echo 1)
        CPU_FREQ_MHZ=$(lscpu 2>/dev/null | awk '/CPU max MHz/{print int($NF); exit}' || echo 0)
        RAM_KB=$(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
        RAM_GB_I=$(( RAM_KB / 1024 / 1024 ))
        RAM_GB_F=$(awk "BEGIN{printf \"%.1f\", $RAM_KB/1048576}")
    fi

    HAS_NVIDIA=0
    GPU_FLAGS=""
    GPU_MODEL=""
    if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null 2>&1; then
        GPU_MODEL=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 || echo "")
        HAS_NVIDIA=1
        GPU_FLAGS="--gpus all"
    fi
}

compute_resources() {
    DOCKER_MEM_GB=$(( RAM_GB_I > 6 ? RAM_GB_I - 2 : 4 ))
    DOCKER_CPUS=$CPU_PHYSICAL
}

_handle_macos_running() {
    local current_context
    current_context=$(docker context show 2>/dev/null || echo "")

    if [[ "$current_context" == "colima" ]]; then
        local colima_status colima_gb colima_cpu
        colima_status=$(colima status --json 2>/dev/null || echo "{}")
        colima_gb=$(echo "$colima_status" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('memory',0)//1073741824)" 2>/dev/null || echo 0)
        colima_cpu=$(echo "$colima_status" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('cpu',0))" 2>/dev/null || echo 0)

        local needs_restart=0
        (( colima_gb  < DOCKER_MEM_GB * 8 / 10 )) && needs_restart=1
        (( colima_cpu < DOCKER_CPUS )) && needs_restart=1

        if [[ "${KEEP_COLIMA:-0}" == "1" ]]; then
            echo "INFO: Keeping Colima as-is (${colima_gb}g RAM, ${colima_cpu} CPUs). Resources will be capped."
        elif (( needs_restart )); then
            echo "Colima is running with ${colima_gb}g RAM and ${colima_cpu} CPUs."
            echo "Optimal for this machine: ${DOCKER_MEM_GB}g RAM and ${DOCKER_CPUS} CPUs."
            printf "Restart Colima now? It will be restored afterwards. [y/N] "
            read -r reply
            if [[ "$reply" =~ ^[Yy]$ ]]; then
                COLIMA_ORIG_GB=$colima_gb
                COLIMA_ORIG_CPU=$colima_cpu
                COLIMA_RESTARTED=1
                echo "→ Restarting Colima (${DOCKER_MEM_GB}g RAM, ${DOCKER_CPUS} CPUs)..."
                colima stop
                colima start --memory "$DOCKER_MEM_GB" --cpu "$DOCKER_CPUS"
            else
                echo "Keeping Colima as-is. Resources will be capped to ${colima_gb}g / ${colima_cpu} CPUs."
            fi
        else
            echo "Colima OK (${colima_gb}g RAM, ${colima_cpu} CPUs)"
        fi
    else
        echo "INFO: Docker Desktop active. Per-container --memory/--cpus limits applied."
        echo "      To increase VM resources, adjust Docker Desktop > Settings > Resources."
    fi
}

_start_docker_macos() {
    if command -v colima &>/dev/null; then
        echo "→ Starting Colima with ${DOCKER_MEM_GB}g RAM, ${DOCKER_CPUS} CPUs..."
        colima start --memory "$DOCKER_MEM_GB" --cpu "$DOCKER_CPUS"
        COLIMA_STARTED=1
        return
    fi

    if [[ -d "/Applications/Docker.app" ]]; then
        echo "→ Starting Docker Desktop..."
        open -a Docker
        local i=0
        while ! docker info &>/dev/null 2>&1; do
            sleep 3
            i=$(( i + 3 ))
            if (( i >= 90 )); then
                echo "ERROR: Docker Desktop did not start within 90s." >&2
                exit 1
            fi
        done
        return
    fi

    if command -v brew &>/dev/null; then
        if [[ "${AUTO_INSTALL:-0}" == "1" ]]; then
            echo "→ Installing Colima and Docker CLI via brew..."
            brew install colima docker
            colima start --memory "$DOCKER_MEM_GB" --cpu "$DOCKER_CPUS"
            return
        else
            echo "ERROR: Docker is not running and neither Colima nor Docker Desktop is installed." >&2
            echo "       Install options:" >&2
            echo "         brew install colima docker  (then: colima start)" >&2
            echo "         https://www.docker.com/products/docker-desktop" >&2
            echo "       Or rerun with AUTO_INSTALL=1 to install automatically." >&2
            exit 1
        fi
    fi

    echo "ERROR: Docker is not available. Install one of:" >&2
    echo "  - Docker Desktop: https://www.docker.com/products/docker-desktop" >&2
    echo "  - Colima: https://github.com/abiosoft/colima" >&2
    exit 1
}

_start_docker_linux() {
    if command -v systemctl &>/dev/null; then
        sudo systemctl start docker
        sleep 2
    elif command -v service &>/dev/null; then
        sudo service docker start
        sleep 2
    fi

    if ! docker info &>/dev/null 2>&1; then
        echo "ERROR: Docker failed to start. Install Docker: https://docs.docker.com/engine/install/" >&2
        exit 1
    fi
}

ensure_docker() {
    local os
    os="$(uname -s)"

    if docker info &>/dev/null 2>&1; then
        if [[ "$os" == "Darwin" ]]; then
            _handle_macos_running
        fi
        return
    fi

    if [[ "$os" == "Darwin" ]]; then
        _start_docker_macos
    else
        _start_docker_linux
    fi
}

pull_image() {
    if ! docker image inspect "$IMAGE" &>/dev/null 2>&1; then
        echo "→ Pulling $IMAGE..."
        docker pull "$IMAGE"
    fi
}

run_benchmark() {
    local DOCKER_PLATFORM=""
    local EMULATED_FLAG=""

    # Parse run_benchmark-specific flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --docker-platform) DOCKER_PLATFORM="$2"; shift 2 ;;
            --emulated) EMULATED_FLAG="--emulated"; shift ;;
            *) break ;;
        esac
    done

    BENCH_CONTAINER_NAME="tfg-bench-$$"

    docker run --rm \
        --name "$BENCH_CONTAINER_NAME" \
        ${DOCKER_PLATFORM:+--platform "$DOCKER_PLATFORM"} \
        --memory "${DOCKER_MEM_GB}g" \
        --cpus "$DOCKER_CPUS" \
        $GPU_FLAGS \
        -e BENCH_HOSTNAME="$(hostname)" \
        -e BENCH_CPU_MODEL="$CPU_MODEL" \
        -e BENCH_CPU_CORES_PHYSICAL="$DOCKER_CPUS" \
        -e BENCH_CPU_CORES_LOGICAL="$DOCKER_CPUS" \
        -e BENCH_CPU_FREQ_MHZ="$CPU_FREQ_MHZ" \
        -e BENCH_RAM_GB="$DOCKER_MEM_GB" \
        -e BENCH_OS="$(uname -s)" \
        -e BENCH_OS_VERSION="$(sw_vers -productVersion 2>/dev/null || uname -r)" \
        -v "$(pwd)/results:/app/results" \
        "$IMAGE" \
        $EMULATED_FLAG \
        "$@" &
    local _docker_pid=$!

    # Start shell timer if time budget is set
    TIMER_PID=""
    if (( TIME_BUDGET_MINS > 0 )); then
        ( sleep $(( TIME_BUDGET_MINS * 60 )) && docker stop "$BENCH_CONTAINER_NAME" 2>/dev/null ) &
        TIMER_PID=$!
    fi

    echo "(Pulsa 'q' para detener el benchmark)"

    (
        while true; do
            if IFS= read -r -n1 -s -t 0.3 key </dev/tty 2>/dev/null; then
                if [[ "$key" == "q" || "$key" == "Q" ]]; then
                    printf "\n→ Benchmark detenido por el usuario.\n" >/dev/tty
                    docker stop "$BENCH_CONTAINER_NAME" >/dev/null 2>&1 || true
                    break
                fi
            fi
        done
    ) &
    local _watcher_pid=$!

    wait "$_docker_pid" 2>/dev/null && _rc=0 || _rc=$?
    kill "$_watcher_pid" 2>/dev/null || true
    wait "$_watcher_pid" 2>/dev/null || true
    if [[ -n "$TIMER_PID" ]]; then
        kill "$TIMER_PID" 2>/dev/null || true
        wait "$TIMER_PID" 2>/dev/null || true
        TIMER_PID=""
    fi
    BENCH_CONTAINER_NAME=""
    return $_rc
}

_qemu_available() {
    docker run --rm --platform linux/amd64 alpine uname -m 2>/dev/null | grep -q x86_64
}

cleanup_image() {
    if [[ "${KEEP_IMAGE:-0}" != "1" ]]; then
        echo "→ Removing image $IMAGE..."
        docker rmi "$IMAGE" 2>/dev/null || true
    fi
}

restore_colima() {
    if (( COLIMA_STARTED )); then
        echo "→ Stopping Colima (was not running before)..."
        colima stop 2>/dev/null || true
    elif (( COLIMA_RESTARTED )); then
        echo "→ Restoring Colima to original state (${COLIMA_ORIG_GB}g RAM, ${COLIMA_ORIG_CPU} CPUs)..."
        colima stop 2>/dev/null || true
        colima start --memory "$COLIMA_ORIG_GB" --cpu "$COLIMA_ORIG_CPU"
    fi
}

cap_to_docker_limits() {
    local docker_ncpu docker_mem_bytes docker_mem_gb
    docker_ncpu=$(docker info --format '{{.NCPU}}' 2>/dev/null || echo "$DOCKER_CPUS")
    docker_mem_bytes=$(docker info --format '{{.MemTotal}}' 2>/dev/null || echo 0)
    docker_mem_gb=$(( docker_mem_bytes / 1073741824 ))

    if (( docker_ncpu < DOCKER_CPUS )); then
        DOCKER_CPUS=$docker_ncpu
    fi
    if (( docker_mem_gb > 0 && docker_mem_gb < DOCKER_MEM_GB )); then
        DOCKER_MEM_GB=$docker_mem_gb
    fi
}

collect_run_args() {
    if [[ ! " $* " =~ " --contributor " ]]; then
        local name=""
        while [[ -z "$name" ]]; do
            printf "Contributor name: "
            read -r name
            name="${name#"${name%%[![:space:]]*}"}"  # ltrim
            name="${name%"${name##*[![:space:]]}"}"  # rtrim
        done
        EXTRA_ARGS+=(--contributor "$name")
    fi

    ask_time_budget
}

main() {
    EXTRA_ARGS=()
    detect_hardware
    compute_resources
    ensure_docker
    cap_to_docker_limits
    collect_run_args "$@"
    pull_image
    echo "Hardware: $CPU_MODEL | ${CPU_PHYSICAL}p/${CPU_LOGICAL}l cores | ${CPU_FREQ_MHZ}MHz | ${RAM_GB_F}GB RAM"
    echo "Docker:   --memory ${DOCKER_MEM_GB}g --cpus $DOCKER_CPUS"

    HOST_ARCH="$(uname -m)"

    if [[ "$HOST_ARCH" =~ ^(arm64|aarch64)$ ]]; then
        echo "→ Primera pasada: build nativo arm64..."
    fi
    run_benchmark "${EXTRA_ARGS[@]}" "$@"

    # Second pass: amd64 via emulation (arm64 hosts only)
    if [[ "$HOST_ARCH" =~ ^(arm64|aarch64)$ ]]; then
        if _qemu_available; then
            echo ""
            echo "→ Segunda pasada: build amd64 vía emulación (Rosetta 2 / QEMU)..."
            run_benchmark --docker-platform linux/amd64 --emulated "${EXTRA_ARGS[@]}" "$@"
        else
            echo "  [INFO] Emulación amd64 no disponible, omitiendo segunda pasada."
        fi
    fi
}

main "$@"
